rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true
        || request.auth.token.email in ["cfv47@naver.com"]
        || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
        )
      );
    }

    function isAdminMemoOnlyUpdate() {
      return isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["adminMemo", "adminMemoUpdatedAt", "adminMemoUpdatedBy"]);
    }

    function isNonEmptyString(value) {
      return value is string && value.size() > 0;
    }

    function isNullableString(value) {
      return value == null || value is string;
    }

    function allowedUserProfileKeys() {
      return [
        "uid",
        "fullName",
        "realName",
        "email",
        "isEmailVerified",
        "emailVerifiedAt",
        "phoneNumber",
        "provider",
        "providerLabel",
        "nickname",
        "caseType",
        "caseStage",
        "deadlineAt",
        "marketingConsent",
        "legalNoticeAcceptedAt",
        "lastLoginAt",
        "termsAccepted",
        "privacyAccepted",
        "sensitiveInfoAccepted",
        "dateOfBirth",
        "birthDate",
        "certificateIdentity",
        "createdAt",
        "updatedAt"
      ];
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasOnly(allowedUserProfileKeys())
        && isNonEmptyString(request.resource.data.fullName)
        && isNullableString(request.resource.data.email)
        && isNullableString(request.resource.data.phoneNumber);
      allow update: if (isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedUserProfileKeys())
        && isNonEmptyString(request.resource.data.fullName)
        && isNullableString(request.resource.data.email)
        && isNullableString(request.resource.data.phoneNumber))
        || isAdminMemoOnlyUpdate();
      allow delete: if false;

      match /enrollments/{courseId} {
        allow read: if isOwner(userId) || isAdmin();
        // Enrollment paymentStatus/enrollmentStatus must be created or changed only by trusted server/Admin SDK after PG verification.
        allow create, update, delete: if false;
      }

      match /courseProgress/{courseId} {
        // Client-side resume backup only. Final completion and certificate eligibility stay server-verified in /courseProgress/{uid_courseId}.
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId)
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.courseId == courseId;
        allow delete: if false;

        match /lessons/{lessonId} {
          allow read: if isOwner(userId) || isAdmin();
          allow create, update: if isOwner(userId)
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.courseId == courseId
            && request.resource.data.lessonId == lessonId;
          allow delete: if false;
        }
      }
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if false;
    }

    match /purchases/{purchaseId} {
      allow read: if isAdmin() || (isSignedIn() && (resource.data.uid == request.auth.uid || resource.data.userId == request.auth.uid));
      allow update: if isAdminMemoOnlyUpdate();
      allow create, delete: if false;
    }

    match /payments/{paymentId} {
      allow read: if isAdmin() || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.uid == request.auth.uid));
      allow update: if isAdminMemoOnlyUpdate();
      allow create, delete: if false;
    }

    match /enrollments/{enrollmentId} {
      allow read: if isAdmin() || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.uid == request.auth.uid));
      allow update: if isAdminMemoOnlyUpdate();
      allow create, delete: if false;
    }

    match /refundPolicies/{policyId} {
      allow read: if true;
      allow write: if false;
    }

    function isCourseProgressConsentWrite() {
      return isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.legalDisclaimerAccepted == true
        && request.resource.data.keys().hasOnly(["uid", "courseId", "courseTitle", "caseType", "legalDisclaimerAccepted", "legalNoticeAcceptedAt", "legalNoticeAcceptedDate", "updatedAt"]);
    }

    function isCourseProgressConsentOnlyUpdate() {
      return isSignedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.legalDisclaimerAccepted == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["uid", "courseId", "courseTitle", "caseType", "legalDisclaimerAccepted", "legalNoticeAcceptedAt", "legalNoticeAcceptedDate", "updatedAt"]);
    }

    match /courseProgress/{progressId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create: if isCourseProgressConsentWrite();
      allow update: if isCourseProgressConsentOnlyUpdate();
      allow delete: if false;
    }

    match /certificates/{certificateId} {
      allow read: if isAdmin() || (isSignedIn() && (resource.data.uid == request.auth.uid || resource.data.userId == request.auth.uid));
      allow update: if isAdminMemoOnlyUpdate();
      allow create, delete: if false;
    }

    match /adminLogs/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    match /aiDocuments/{documentId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.legalDisclaimerAccepted == true
        && request.resource.data.userConfirmedManualReview == true;
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && isNonEmptyString(request.resource.data.authorName)
        && isNonEmptyString(request.resource.data.courseLabel)
        && isNonEmptyString(request.resource.data.title)
        && isNonEmptyString(request.resource.data.body)
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
